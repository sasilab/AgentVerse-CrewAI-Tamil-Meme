# Bring-your-own-key. Uncomment whichever provider you have — the app
# auto-detects which key is set and uses that. You only need ONE.
#
# Preference order if multiple are set: Groq > Gemini > OpenAI > Ollama.

# ---------- Groq (recommended for learners — free + fast) ----------
# Get a free key: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_key_here

# ---------- Gemini (free tier) ----------
# Get a free key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_key_here

# ---------- OpenAI (paid) ----------
# Get a key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key_here

# ---------- Ollama (local, no key required) ----------
# Install Ollama: https://ollama.com/download
# Then: `ollama serve` and `ollama pull llama3.2`
# (Auto-detected if port 11434 is open. Override below if needed.)
# OLLAMA_MODEL=ollama/llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ---------- Advanced: override the default model ----------
# Format follows LiteLLM's "provider/model" convention.
# Examples:
#   MODEL=groq/llama-3.1-8b-instant
#   MODEL=gemini/gemini-2.5-flash
#   MODEL=gpt-4o-mini
#   MODEL=ollama/mistral
# MODEL=
